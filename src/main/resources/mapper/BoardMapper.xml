<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.study.board.mapper.BoardMapper">

    <select id="findAll" resultType="com.study.board.domain.Board">
        SELECT *
        FROM board
        ORDER BY board_id DESC
    </select>

    <!-- 제목 검색. keyword가 없으면 <if>가 빠져 전체 조회가 된다. -->
    <select id="search" resultType="com.study.board.domain.Board">
        SELECT *
        FROM board
        <if test="keyword != null and keyword != ''">
            WHERE title LIKE CONCAT('%', #{keyword}, '%')
        </if>
        ORDER BY board_id DESC
    </select>

</mapper>
